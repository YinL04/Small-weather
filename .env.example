# Copy this file to .env and fill in values as needed.

# Optional: if set, the agent will use an OpenAI-compatible model to write
# richer travel advice and attraction recommendations.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Weather service settings.
WTTR_LANG=zh
WTTR_TIMEOUT=10

# Optional default city used when you press Enter at the prompt.
DEFAULT_CITY=
